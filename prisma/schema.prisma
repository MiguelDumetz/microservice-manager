generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64", "darwin", "windows", "linux-musl"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Project {
  id       Int       @id @default(autoincrement())
  name     String
  services Service[]
}

model Service {
  id        Int     @id @default(autoincrement())
  name      String
  url       String
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
